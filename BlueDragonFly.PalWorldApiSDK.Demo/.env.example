# Copia este archivo como .env y rellena tus valores reales.
# La demo no envia estos valores a ningun servidor externo:
# solo los usa para conectarse a tu propio servidor Palworld.

# URL del servidor Palworld. Puedes usar la URL base (http://localhost:8212)
# o la URL completa de la API (http://localhost:8212/v1/api).
PALWORLD_SERVER_URL=http://localhost:8212

# Credenciales de administrador de la API REST.
PALWORLD_ADMIN_USERNAME=admin
PALWORLD_ADMIN_PASSWORD=tu-contrasena-aqui

# Comando que ejecuta la demo. Usa 'help' para ver todos los comandos disponibles
# sin necesidad de conectarte al servidor.
PALWORLD_DEMO_COMMAND=info

# Variables opcionales segun el comando elegido:
# PALWORLD_STEAM_ID=steam_00000000000000000
# PALWORLD_MESSAGE=El servidor se reiniciara pronto.
# PALWORLD_SHUTDOWN_WAIT_SECONDS=30
